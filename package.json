{
  "name": "vscode-mdpa",
  "displayName": "Kratos MDPA Preview",
  "description": "Preview, organize, and manage Kratos Multiphysics .mdpa model-part files: 3D mesh viewer with a navigable ModelPart/SubModelPart outline and toggleable layers.",
  "version": "0.9.0",
  "icon": "images/icon.png",
  "publisher": "kratos-multiphysics",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loumalouomega/VSCode-MDPA-Preview.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "kratos",
    "mdpa",
    "mesh",
    "finite element",
    "fem"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/",
    "media/",
    "syntaxes/",
    "language-configuration.json"
  ],
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "mdpa",
        "aliases": [
          "Kratos MDPA",
          "mdpa"
        ],
        "extensions": [
          ".mdpa"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mdpa",
        "scopeName": "source.mdpa",
        "path": "./syntaxes/mdpa.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "kratos.mdpaPreview",
        "displayName": "Kratos MDPA Preview",
        "selector": [
          {
            "filenamePattern": "*.mdpa"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "kratos.vtkPreview",
        "displayName": "Kratos VTK Preview",
        "selector": [
          {
            "filenamePattern": "*.vtk"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "kratos.mdpa.openPreview",
        "title": "Open MDPA Preview",
        "category": "Kratos MDPA"
      },
      {
        "command": "kratos.mdpa.resetCamera",
        "title": "Reset Camera",
        "category": "Kratos MDPA"
      },
      {
        "command": "kratos.mdpa.toggleNodeIds",
        "title": "Toggle Node IDs",
        "category": "Kratos MDPA"
      },
      {
        "command": "kratos.mdpa.computeQuality",
        "title": "Compute Mesh Quality",
        "category": "Kratos MDPA"
      },
      {
        "command": "kratos.mdpa.fieldVisualization",
        "title": "Field Visualization",
        "category": "Kratos MDPA"
      },
      {
        "command": "kratos.mdpa.findEntity",
        "title": "Find Entity by ID",
        "category": "Kratos MDPA"
      },
      {
        "command": "kratos.vtk.openPreview",
        "title": "Open VTK Preview",
        "category": "Kratos VTK"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kratos.mdpa.openPreview",
          "when": "resourceExtname == .mdpa && activeCustomEditorId != kratos.mdpaPreview",
          "group": "navigation"
        },
        {
          "command": "kratos.vtk.openPreview",
          "when": "resourceExtname == .vtk && activeCustomEditorId != kratos.vtkPreview",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "kratos.mdpa.openPreview",
          "when": "resourceExtname == .mdpa",
          "group": "navigation"
        },
        {
          "command": "kratos.vtk.openPreview",
          "when": "resourceExtname == .vtk",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "typecheck": "tsc --noEmit -p ./",
    "build:tests": "tsc -p ./tsconfig.test.json",
    "test": "npm run build:tests && node --test out/test/",
    "install-ext": "bash install.sh"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@kitware/vtk.js": "^29.6.0"
  }
}
